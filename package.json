{
    "name": "@arpadroid/signals",
    "version": "0.0.1",
    "description": "Isomorphic pub/sub observer pattern implementation for javascript projects",
    "keywords": [
        "javascript",
        "isomorphic",
        "signals",
        "observer",
        "pubsub",
        "events"
    ],
    "types": "./dist/@types/index.d.ts",
    "type": "module",
    "scripts": {
        "clean:install": "npm run clean && npm install",
        "clean": "rm -rf ./dist ./node_modules package-lock.json && npm i",
        "lint": "eslint src/**/*.{js,mjs}",
        "prepublishOnly": "npm run test && npm run lint && npm run build",
        "test:coverage": "jest --coverage",
        "test:watch": "jest --watch",
        "test": "jest",
        "build": "tsc"
    },
    "exports": {
        ".": {
            "types": "./dist/@types/types.compiled.d.ts",
            "import": "./src/index.js"
        },
        "./observerTool": {
            "types": "./dist/@types/observerTool/observerTool.d.ts",
            "default": "./src/observerTool/observerTool.js"
        }
    },
    "files": [
        "src/",
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arpadroid/signals.git"
    },
    "author": "Andres Vaquero / @arpadroid",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/arpadroid/signals/issues"
    },
    "homepage": "https://github.com/arpadroid/signals#readme",
    "dependencies": {
        "@arpadroid/tools-iso": "file:../tools-iso"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.2",
        "@eslint/js": "^10.0.1",
        "@jest/globals": "^30.2.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.0",
        "babel-jest": "^30.2.0",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    }
}
